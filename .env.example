# Telegram bot credentials (see README for how to get these)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic API key - the model does the actual chart/volume/wallet-risk judgment.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Comma-separated chain IDs to scan (GeckoTerminal network ids - "solana" is the target here)
CHAINS=solana

# Hard floors applied before the expensive analysis step (arithmetic filters, not judgment).
# These are outer bounds only - primary preference ($100K-$2M, 0-12h) vs. exceptions
# (up to these outer bounds, only if genuinely flashing) is judged by Claude in src/prompt.ts.
MIN_MARKET_CAP_USD=75000
MAX_MARKET_CAP_USD=5000000
MIN_LIQUIDITY_USD=25000
MAX_AGE_HOURS=72

# Two-stage cap matching the discover -> hard-filter -> top30 -> quantitative-score -> top10 -> LLM pipeline.
MAX_SURVIVORS=30
MAX_DEEP_ANALYZE=10
