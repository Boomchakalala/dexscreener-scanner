# Telegram bot credentials (see README for how to get these)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic API key - the model does the actual chart/volume/wallet-risk judgment.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Comma-separated chain IDs to scan (GeckoTerminal network ids - "solana" is the target here)
CHAINS=solana

# Only consider pump.fun-launched tokens (mint addresses ending in "pump" - the vanity
# suffix survives migration). Non-pump.fun launch infra proved to be where the repeat
# garbage came from. Set to "false" to widen back out.
PUMPFUN_ONLY=true

# Hard floors applied before the expensive analysis step (arithmetic filters, not judgment).
# Spans the full three-universe window (Fresh 0-2h/$30K-$300K, Survivors 2-8h/$100K-$1M,
# Momentum 8-24h/$250K-$3M) - which universe a candidate falls in is judged by Claude in
# src/prompt.ts, not filtered here.
MIN_MARKET_CAP_USD=30000
MAX_MARKET_CAP_USD=3000000
MIN_LIQUIDITY_USD=15000
MAX_AGE_HOURS=24

# Four-stage pipeline: raw discovery -> hard floors -> chart-proxy shortlist (MAX_SHORTLIST)
# -> real-candle quality re-rank -> RugCheck as the final gate -> top MAX_DEEP_ANALYZE to the LLM.
MAX_SHORTLIST=32
MAX_DEEP_ANALYZE=10
