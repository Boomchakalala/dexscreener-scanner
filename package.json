{
  "name": "dexscreener-scanner",
  "version": "1.0.0",
  "description": "Scans Solana memecoins for early-stage setups and sends Telegram alerts on a schedule, plus a fast flash-alert check.",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:flash": "node dist/flash.js",
    "start:listen": "node dist/listen.js",
    "start:watchlist-check": "node dist/watchlistCheck.js",
    "start:ledger-check": "node dist/ledgerCheck.js",
    "dev": "tsx src/main.ts",
    "dev:flash": "tsx src/flash.ts",
    "dev:listen": "tsx src/listen.ts",
    "dev:watchlist-check": "tsx src/watchlistCheck.ts",
    "dev:ledger-check": "tsx src/ledgerCheck.ts",
    "build": "tsc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "dotenv": "^17.4.2"
  }
}
